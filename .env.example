# ============================================================
# AuthClaw Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# Application
APP_NAME=AuthClaw
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://authclaw:authclaw_secret@localhost:5433/authclaw
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6380/0

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (Fernet key for provider API keys)
ENCRYPTION_KEY=your-fernet-key-generate-with-cryptography-fernet

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# OpenAI (Default provider for testing)
OPENAI_API_KEY=sk-your-openai-api-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
