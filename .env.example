# AuthClaw root environment example
# Copy to .env for local development only. Production values must come from a
# secret manager or deployment environment, not from this file.

# Application
APP_NAME=AuthClaw
APP_ENV=development
APP_DEBUG=false
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL
# Local Compose maps db to localhost:5434. The runtime role/password are created
# by the current RLS migration for local development.
DATABASE_URL=postgresql+asyncpg://authclaw_app:authclaw_app_password@localhost:5434/authclaw
ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5434/authclaw
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_CONNECTOR_TOPIC=authclaw.connector.scan

# Vault local dev
VAULT_ADDR=http://localhost:8200
VAULT_DEV_ROOT_TOKEN_ID=local-vault-root-token
VAULT_TOKEN=local-vault-root-token
VAULT_TRANSIT_KEY=authclaw-key
VAULT_TRANSIT_MOUNT=transit
VAULT_INTEGRATION_MOUNT=secret
VAULT_INTEGRATION_PATH_PREFIX=authclaw/tenants

# ClickHouse local dev
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=authclaw
CLICKHOUSE_PASSWORD=authclaw_clickhouse_local_password
CLICKHOUSE_DB=authclaw

# Security
# Generate real production values outside the repo.
JWT_SECRET_KEY=replace-with-secret-manager-value
JWT_SECRET=replace-with-secret-manager-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=replace-with-fernet-key-generated-outside-repo
ENCRYPTION_PROVIDER=local

# Provider keys are optional and must not be committed.
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
AZURE_OPENAI_API_KEY=

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Security pipeline feature flags
FF_SECURITY_PIPELINE=true
FF_INBOUND_SCAN=true
FF_OUTBOUND_SCAN=true
FF_STREAM_SCAN=false
FF_SECURITY_SHADOW_MODE=true

# Policy engine runtime
# python = existing YAML/Python evaluator
# opa = authoritative OPA/Rego HTTP runtime
# hybrid = compare OPA and Python decisions, fail closed on mismatch
POLICY_ENGINE_MODE=python
ENABLE_OPA_RUNTIME_INTEGRATION=false
OPA_URL=http://localhost:8181/v1/data/authclaw/gateway/decision
OPA_POLICY_URL=http://localhost:8181/v1/data/authclaw/gateway/decision
OPA_RUNTIME_MODE=STRICT
OPA_STRICT_MODE=true
OPA_FAIL_CLOSED=true
OPA_TIMEOUT_SECONDS=2.0

# Sprint 2 connector feature flags and safety limits
FF_USE_REAL_CONNECTORS=true
MAX_FINDINGS_PER_SYNC=10000
MAX_SCAN_DURATION=300
CONNECTOR_SCAN_LOCK_TTL_SECONDS=360
CONNECTOR_WORKER_POLL_INTERVAL_SECONDS=60
MAX_AGENT_CONTEXT_FINDINGS=15

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
